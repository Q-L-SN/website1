{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Server",
      "program": "${workspaceFolder}\\.vscode\\debug-entry.mjs",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
